From f078caa301422bfacb736583f76e7cc382875abc Mon Sep 17 00:00:00 2001
From: LegionGames Dev <git@legiongames.ru>
Date: Fri, 10 Apr 2026 13:37:09 +0300
Subject: [PATCH 09/11] Phase 2: Add AmneziaWG to management server and Docker

- Add AmneziaConfig to PeerConfig in grpc conversion.go
- Copy amneziawg package to new management tree
- Create Dockerfile.mgmt for custom management image
- Update docker-compose.yml: build from source, use management subcommand
- Privacy: --disable-anonymous-metrics, --disable-geolite-update, NB_DISABLE_GEOLOCATION
- Management container running and healthy

Co-authored-by: Qwen-Coder <qwen-coder@alibabacloud.com>
---
 Dockerfile.mgmt                               |  20 ++
 .../server/amneziawg/amneziawg_env.go         | 211 ++++++++++++++++++
 .../internals/shared/grpc/conversion.go       |   1 +
 3 files changed, 232 insertions(+)
 create mode 100644 Dockerfile.mgmt
 create mode 100644 management/internals/server/amneziawg/amneziawg_env.go

diff --git a/Dockerfile.mgmt b/Dockerfile.mgmt
new file mode 100644
index 000000000..c12c72318
--- /dev/null
+++ b/Dockerfile.mgmt
@@ -0,0 +1,20 @@
+FROM golang:1.26-alpine AS builder
+
+RUN apk add --no-cache git gcc musl-dev protobuf-dev protoc
+
+WORKDIR /src
+COPY go.mod go.sum ./
+RUN go mod download
+
+COPY . .
+
+RUN CGO_ENABLED=1 GOOS=linux go build -o /out/netbird-mgmt ./management/main.go
+
+FROM alpine:3.21
+RUN apk add --no-cache ca-certificates
+
+COPY --from=builder /out/netbird-mgmt /usr/local/bin/netbird-mgmt
+
+EXPOSE 80
+
+ENTRYPOINT ["netbird-mgmt"]
diff --git a/management/internals/server/amneziawg/amneziawg_env.go b/management/internals/server/amneziawg/amneziawg_env.go
new file mode 100644
index 000000000..15320d0ea
